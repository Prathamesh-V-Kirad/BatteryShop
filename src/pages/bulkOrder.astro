---
import Layout from "../layouts/Layout.astro"
import BulkOrderForm from "../components/BulkOrderForm.jsx"
import Navbar from '../components/Navbar.astro';
import {

  Battery,

} from 'lucide-react';
---

<Layout title="Bulk Orders">
    <div class="flex min-h-screen flex-col">
      <Navbar />
    
      <main class="flex-1">
            
        <div class="max-w-5xl mx-auto px-4 py-10">
            
            <h1 class="text-3xl font-bold mb-6">
            Business / Bulk Orders
            </h1>

            <p class="text-zinc-600 mb-8">
            Select products, enter quantity, or request custom items.
            </p>

            <BulkOrderForm client:load />

        </div>

      </main>
    
       
      <footer class="border-t bg-zinc-50 py-12">
        <div class="container mx-auto px-4 text-center space-y-6">
          <div class="flex justify-center items-center gap-2 font-bold text-xl">
            <Battery className="h-6 w-6 text-primary" />
            VOLT<span class="text-primary">CORE</span>
          </div>
          <p class="text-xs uppercase tracking-widest text-muted-foreground">
            © 2025 VoltCore Power Solutions. All rights reserved.
          </p>
        </div>
      </footer>
    </div>

</Layout>