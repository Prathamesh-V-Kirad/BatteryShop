---

import { testimonials } from '../data/testimonials';

---

<section class="py-20 bg-white">
  <div class="container mx-auto px-4 text-center">
    
    <h2 class="text-3xl font-bold mb-10">What Our Customers Say</h2>

    <div class="relative w-full max-w-6xl mx-auto">
      

      <div id="carousel" class="overflow-hidden relative w-full px-6">
  <div id="slides" class="flex gap-8 transition-transform duration-500 will-change-transform">
    
    {testimonials.map((t) => (
      <div class="flex-shrink-0 w-[300px] sm:w-[360px] lg:w-[420px]">
<div class="bg-white border rounded-xl p-6 shadow-sm h-full flex flex-col">
  
  {/* Header */}
  <div class="flex items-center gap-3 mb-4">
    <img src={t.img} class="w-10 h-10 rounded-full" />
    <div>
      <p class="font-semibold text-sm">{t.name}</p>
      <p class="text-xs text-gray-500">{t.relative_time_description}</p>
    </div>
  </div>

  

  {/* Review */}
  <div class="flex-1 flex items-center justify-center">
  <p class="text-muted-foreground italic text-sm leading-relaxed max-w-[90%] text-center">
    "{t.text}"
  </p>
</div>

  {/* Stars */}

    <div class="flex mb-3 mx-auto">
    {Array.from({ length: 5 }).map((_, i) => (
      <span class={i < t.rating ? "text-yellow-400" : "text-gray-300"}>
        ★
      </span>
    ))}
  </div>

  {/* Footer */}
  <div class="mt-4 text-xs text-gray-400">
    Google Review
  </div>
</div>
      </div>
    ))}

  </div>
</div>

      <!-- Controls -->
      <div class="flex justify-center gap-4 mt-6">
        <button id="prev" class="px-4 py-2 bg-zinc-200 rounded hover:bg-zinc-300">
          Prev
        </button>
        <button id="next" class="px-4 py-2 bg-primary text-white rounded hover:opacity-90">
          Next
        </button>
      </div>
      <a
      href="https://www.google.com/maps/place/National+Battery/@19.08052,73.004866,17z/data=!4m8!3m7!1s0x3be7c130a892d21d:0x7afcfdf4382bbe15!8m2!3d19.08052!4d73.004866!9m1!1b1!16s%2Fg%2F1jglys_8k?hl=en&entry=ttu&g_ep=EgoyMDI2MDQwOC4wIKXMDSoASAFQAw%3D%3D" target="_blank"
        class="inline-block mt-6 text-blue-600 underline text-sm"
      >
        View all reviews on Google
      </a>
    </div>
    <div class="flex justify-center gap-2 mt-4" id="dots"></div>
  </div>


<script is:inline>
setTimeout(() => {
  const slides = document.getElementById("slides");
  const nextBtn = document.getElementById("next");
  const prevBtn = document.getElementById("prev");
  const dotsContainer = document.getElementById("dots");

  if (!slides) return;

  const gap = 32;
  const originals = [...slides.children];
  const total = originals.length;

  // 🔁 Clone ALL slides before & after
  const before = originals.map(el => el.cloneNode(true));
  const after = originals.map(el => el.cloneNode(true));

  before.reverse().forEach(el => slides.insertBefore(el, slides.firstChild));
  after.forEach(el => slides.appendChild(el));

  let allSlides = [...slides.children];

  // Start from first REAL set
  let index = total;

  let cardWidth = allSlides[0].clientWidth + gap;
  let isTransitioning = false;

  function setPosition(animate = true) {
    slides.style.transition = animate ? "transform 0.5s ease" : "none";

    const containerWidth = slides.parentElement.clientWidth;
    const offset = (containerWidth - cardWidth) / 2;

    slides.style.transform =
      `translateX(${offset - index * cardWidth}px)`;
  }

  function next() {
    if (isTransitioning) return;
    isTransitioning = true;
    index++;
    setPosition(true);
    updateDots();
  }

  function prev() {
    if (isTransitioning) return;
    isTransitioning = true;
    index--;
    setPosition(true);
    updateDots();
  }

  slides.addEventListener("transitionend", () => {
    isTransitioning = false;

    // 🔁 Seamless reset (middle zone)
    if (index >= total * 2) {
      index = total;
      setPosition(false);
    }

    if (index < total) {
      index = total * 2 - 1;
      setPosition(false);
    }

    
  });

  function updateDots() {
    const realIndex = index % total;

    [...dotsContainer.children].forEach((dot, i) => {
      dot.classList.toggle("bg-primary", i === realIndex);
      dot.classList.toggle("bg-zinc-400", i !== realIndex);
    });
  }

  // Controls
  nextBtn?.addEventListener("click", next);
  prevBtn?.addEventListener("click", prev);

  // Dots
  dotsContainer.innerHTML = "";
  for (let i = 0; i < total; i++) {
    const dot = document.createElement("button");
    dot.className = "w-2 h-2 rounded-full bg-zinc-400";

    dot.addEventListener("click", () => {
      index = i + total;
      setPosition(true);
      updateDots();
    });

    dotsContainer.appendChild(dot);
  }

  // Resize fix
  window.addEventListener("resize", () => {
    cardWidth = allSlides[0].clientWidth + gap;
    setPosition(false);
  });

  // Auto scroll
  let auto = setInterval(next, 4000);

  slides.addEventListener("mouseenter", () => clearInterval(auto));
  slides.addEventListener("mouseleave", () => {
    auto = setInterval(next, 4000);
  });

  // Init
  setPosition(false);
  updateDots();

}, 0);
</script>
</section>